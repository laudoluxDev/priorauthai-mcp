{
  "schema_version": "1.0",
  "product_id": "priorauthai",
  "product_name": "PriorAuthAI",
  "official_domain": "priorauthai.com",
  "official_github_repo": "https://github.com/laudoluxDev/priorauthai-mcp",
  "official_package": "@tasksai/install",
  "installer": {
    "preferred": "npx",
    "npx": {
      "command": "npx",
      "args": [
        "@tasksai/install",
        "priorauthai",
        "--source",
        "https://github.com/laudoluxDev/priorauthai-mcp"
      ],
      "requires": [
        "node",
        "npm",
        "npx"
      ]
    }
  },
  "supported_clients": [
    "claude_desktop",
    "cursor",
    "windsurf"
  ],
  "permissions": {
    "write_paths": {
      "macos": [
        "~/Library/Application Support/TasksAI/priorauthai",
        "~/Library/Application Support/Claude/claude_desktop_config.json",
        "~/.cursor/mcp.json",
        "~/.codeium/windsurf/mcp_config.json"
      ],
      "windows": [
        "%LOCALAPPDATA%\\TasksAI\\priorauthai",
        "%APPDATA%\\Claude\\claude_desktop_config.json",
        "%USERPROFILE%\\.cursor\\mcp.json",
        "%USERPROFILE%\\.codeium\\windsurf\\mcp_config.json"
      ],
      "linux": [
        "~/.local/share/TasksAI/priorauthai",
        "~/.config/Claude/claude_desktop_config.json",
        "~/.cursor/mcp.json",
        "~/.codeium/windsurf/mcp_config.json"
      ]
    },
    "environment_overrides": [
      "TASKSAI_INSTALL_DIR"
    ],
    "notes": "TASKSAI_INSTALL_DIR or --install-dir may point to an exact alternate product install directory in restricted agent environments."
  },
  "auth": {
    "method": "browser_device_flow",
    "connect_url": "https://priorauthai.com/connect",
    "fallback": "license_key"
  },
  "security": {
    "require_domain_verification": true,
    "require_repo_verification": true,
    "disallow_arbitrary_manifest_commands": true,
    "native_installer_user_approval_required": false
  },
  "health_check": {
    "command": "npx",
    "args": [
      "@tasksai/install",
      "priorauthai",
      "doctor"
    ]
  },
  "uninstall": {
    "command": "npx",
    "args": [
      "@tasksai/install",
      "priorauthai",
      "uninstall"
    ]
  },
  "support": {
    "url": "https://priorauthai.com/support",
    "email": "support@priorauthai.com"
  }
}
